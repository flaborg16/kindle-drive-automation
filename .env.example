# Google Drive
# Use a service account JSON. Either set GOOGLE_SERVICE_ACCOUNT_JSON to the raw JSON or base64 of the JSON,
# or set GOOGLE_SERVICE_ACCOUNT_FILE to a local file path.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
KINDLE_ROOT_FOLDER_NAME=Kindle_Automation
BOOKS_FOLDER_NAME=Books_To_Kindle
NOTEBOOKS_FOLDER_NAME=Notebooks
SENT_FOLDER_NAME=Sent_To_Kindle
PROCESSED_NOTEBOOKS_FOLDER_NAME=Processed_Notebooks
FAILED_FOLDER_NAME=Failed
QUOTATIONS_FOLDER_NAME=Quotations

# Kindle delivery via email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=mahipalbablu16@gmail.com
SMTP_APP_PASSWORD=otieheyymamxifer
KINDLE_EMAIL=mahipalbablu16_6kzRLw@kindle.com
EMAIL_FROM_NAME=Kindle Drive Automation

# Limits
MAX_EMAIL_ATTACHMENT_MB=24
QUOTE_IMAGE_WIDTH=1236
QUOTE_IMAGE_HEIGHT=1648

# Processing behavior
PROCESS_NOTES_AS_QUOTES=true
DELETE_LOCAL_WORKDIR_AFTER_RUN=true
